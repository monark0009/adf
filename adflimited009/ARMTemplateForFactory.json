			"type": "string",
			"defaultValue": "https://adlslimited009.dfs.core.windows.net/"
		},
		"AzureDataLakeStorage2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlslimited009.dfs.core.windows.net/"
